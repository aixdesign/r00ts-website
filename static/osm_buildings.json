{
    "version": 8,
    "name": "r00ts Style",
    "metadata": {
        "maputnik:renderer": "mlgljs"
    },
    "sources": {
        "openmaptiles": {
            "type": "vector",
            "url": "https://tiles.openfreemap.org/planet"
        }
    },
    "sprite": "",
    "layers": [
        {
            "id": "buildings",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "building",
            "paint": {
                "fill-color": "#ff3f99",
                "fill-opacity": {
                    "stops": [
                        [
                            13,
                            0.5
                        ],
                        [
                            16,
                            1.0
                        ]
                    ]
                },
                "fill-outline-color": "#ffd0d0"
            }
        },
        {
            "id": "residential",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landuse",
            "minzoom": 9,
            "maxzoom": 24,
            "filter": [
                "any",
                [
                    "==",
                    "class",
                    "residential"
                ],
                [
                    "==",
                    "class",
                    "industrial"
                ]
            ],
            "layout": {
                "visibility": "visible"
            },
            "paint": {
                "fill-color": "#ff3f99",
                "fill-opacity": {
                    "stops": [
                        [
                            9,
                            0
                        ],
                        [
                            13,
                            0.5
                        ],
                        [
                            16,
                            0.1
                        ]
                    ]
                },
                "fill-outline-color": "#ffd0d0"
            }
        },
        {
            "id": "place_label_city",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "place",
            "minzoom": 10,
            "filter": [
                "all",
                [
                    "==",
                    "class",
                    "city"
                ],
                [
                    "==",
                    "$type",
                    "Point"
                ]
            ],
            "layout": {
                "text-pitch-alignment": "map",
                "text-field": "{name:en}",
                "text-font": [
                    "GT Pressura Mono",
                    "monospace"
                ]
            },
            "paint": {
                "text-halo-color": "rgba(255, 255, 255, 1)",
                "text-halo-width": 3
            }
        },
        {
            "id": "place_label_country",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "place",
            "minzoom": 5,
            "filter": [
                "all",
                [
                    "==",
                    "class",
                    "country"
                ]
            ],
            "layout": {
                "text-pitch-alignment": "map",
                "text-field": "{name:en}",
                "text-font": [
                    "GT Pressura Mono",
                    "monospace"
                ]
            },
            "paint": {
                "text-halo-color": "rgba(255, 255, 255, 1)",
                "text-halo-width": 3
            }
        }
    ],
    "id": "he328kb"
}
